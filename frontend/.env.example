# ─── LUMIÈRE Frontend Environment ───────────────────────────────────────────

# Backend URL (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Google OAuth Client ID (get from console.cloud.google.com)
# Must match GOOGLE_CLIENT_ID in backend .env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Stripe Publishable Key (get from dashboard.stripe.com)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
